Options -MultiViews
DirectoryIndex app.html
RewriteEngine On
RewriteBase /LIS/

# Proxy /LIS/api/* → Express server on port 3001
<IfModule mod_proxy.c>
  RewriteRule ^api/(.*)$ http://localhost:3001/api/$1 [P,L]
</IfModule>

# Production entry is app.html (index.html is reserved for the Vite dev server).
RewriteRule ^$ /LIS/app.html [L]
RewriteRule ^app\.html$ - [L]

# SPA fallback: ทุก route ที่ไม่ใช่ไฟล์จริง → app.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /LIS/app.html [L]
